#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: tmux-log [options]

Options:
  -s, --session NAME   tmux session name (default: $TMUX_LOG_SESSION or ops)
  -t, --target WIN.P   target pane to log (default: $TMUX_LOG_TARGET or 0.0)
  -l, --log PATH       log file path (default: $TMUX_LOG_PATH or ~/.cache/tmux-log/window0.log)
  -c, --current        use the current tmux pane as target (implies -s/-t from tmux)
      --auto-log       choose a per-pane log file under ~/.cache/tmux-log/<session>/
      --raw            do not clean ANSI/backspaces; write raw output
      --fresh          truncate the log file before piping
      --stop           stop piping for the target pane
  -h, --help           show this help message

Behavior:
- Ensures the tmux session exists (creates if missing).
- Pipes the chosen pane to the log file (optionally cleaned via ansi2txt | col -b when available).
- Attaches if you are not already inside tmux; otherwise prints a ready message.
EOF
}

session="${TMUX_LOG_SESSION:-ops}"
target="${TMUX_LOG_TARGET:-0.0}"
log_file="${TMUX_LOG_PATH:-$HOME/.cache/tmux-log/window0.log}"
venv_activate="${TMUX_LOG_VENV:-$HOME/venv/ansible9/bin/activate}"
raw=0
fresh=0
current=0
auto_log=0
stop=0
log_file_explicit=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    -s|--session)
      [[ $# -lt 2 ]] && { echo "Missing value for $1" >&2; exit 1; }
      session="$2"
      shift 2
      ;;
    -t|--target)
      [[ $# -lt 2 ]] && { echo "Missing value for $1" >&2; exit 1; }
      target="$2"
      shift 2
      ;;
    -l|--log)
      [[ $# -lt 2 ]] && { echo "Missing value for $1" >&2; exit 1; }
      log_file="${2/#\~/$HOME}"
      log_file_explicit=1
      shift 2
      ;;
    -c|--current)
      current=1
      shift
      ;;
    --auto-log)
      auto_log=1
      shift
      ;;
    --raw)
      raw=1
      shift
      ;;
    --fresh)
      fresh=1
      shift
      ;;
    --stop)
      stop=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      break
      ;;
  esac
done

if ! command -v tmux >/dev/null 2>&1; then
  echo "tmux is required" >&2
  exit 1
fi

if [[ $current -eq 1 ]]; then
  if [[ -z "${TMUX:-}" ]]; then
    echo "--current requires running inside tmux" >&2
    exit 1
  fi

  session="$(tmux display-message -p '#{session_name}')"
  window_index="$(tmux display-message -p '#{window_index}')"
  pane_index="$(tmux display-message -p '#{pane_index}')"
  target="${window_index}.${pane_index}"

  if [[ $auto_log -eq 1 ]]; then
    if [[ $log_file_explicit -eq 1 ]]; then
      echo "Cannot combine --auto-log with --log" >&2
      exit 1
    fi
    log_file="$HOME/.cache/tmux-log/${session}/w${window_index}p${pane_index}.log"
  fi
fi

mkdir -p "$(dirname "$log_file")"

sh_quote() {
  local s="$1"
  s=${s//\'/\'\"\'\"\'}
  printf "'%s'" "$s"
}

resolve_cmd() {
  command -v "$1" 2>/dev/null || true
}

stdbuf_cmd="$(resolve_cmd stdbuf)"
sed_cmd="$(resolve_cmd sed)"
tee_cmd="$(resolve_cmd tee)"
if [[ -z "$tee_cmd" ]]; then
  tee_cmd="tee"
fi

log_sh="$(sh_quote "$log_file")"

if [[ $fresh -eq 1 ]]; then
  : > "$log_file"
fi

if [[ $stop -eq 1 ]]; then
  tmux pipe-pane -t "${session}:${target}" ""
  echo "Stopped logging pane ${target} in session '${session}'."
  exit 0
fi

if ! tmux has-session -t "$session" 2>/dev/null; then
  tmux new-session -d -s "$session" -n logs
fi

# Ensure a helper window with commented Codex prompts exists at index 1.
if ! tmux list-windows -t "$session" -F '#{window_index}' | grep -qx 1; then
  sample_prompt="# Codex prompt ideas (copy/paste then edit):
# Read ${log_file}, last 300 lines. Summarize new errors and unusual patterns.
# If multiple logs, name each path and what to compare.
# Add timeframe or hypothesis to focus the answer.
#
# To start logging another pane, for example window 1 pane 0:
# tmux pipe-pane -o -t ${session}:1.0 'ansi2txt | col -b | tee -a ~/.cache/tmux-log/window1.log'"

  codex_cmd=""
  if [[ -f "$venv_activate" ]]; then
    codex_cmd+="source $(printf "%q" "$venv_activate"); "
  fi
  codex_cmd+="printf '%s\n' \"$sample_prompt\"; exec \$SHELL"
  tmux new-window -t "$session" -n codex "$codex_cmd"
fi

# Build the pipe command with optional cleaning of ANSI/backspaces.
pipe_cmd=""
if [[ $raw -eq 1 ]]; then
  if [[ -n "$stdbuf_cmd" ]]; then
    pipe_cmd="$stdbuf_cmd -oL -eL $tee_cmd -a $log_sh"
  else
    pipe_cmd="$tee_cmd -a $log_sh"
  fi
else
  ansi_cmd="$(resolve_cmd ansi2txt)"
  # Avoid `col -b` here: it buffers until EOF on some systems, which makes the
  # log look empty while tmux piping is active.
  if [[ -n "$sed_cmd" && -n "$stdbuf_cmd" ]]; then
    if [[ -n "$ansi_cmd" ]]; then
      pipe_cmd="$stdbuf_cmd -oL -eL $ansi_cmd | $stdbuf_cmd -oL -eL $sed_cmd -r ':a; s/.\\x08//; ta' | $stdbuf_cmd -oL -eL $tee_cmd -a $log_sh"
    else
      pipe_cmd="$stdbuf_cmd -oL -eL $sed_cmd -r 's/\\x1B\\[[0-9;]*[[:alpha:]]//g; :a; s/.\\x08//; ta' | $stdbuf_cmd -oL -eL $tee_cmd -a $log_sh"
    fi
  else
    pipe_cmd="$tee_cmd -a $log_sh"
  fi
fi

# Reset and apply logging to the target pane.
tmux pipe-pane -t "${session}:${target}" ""
tmux pipe-pane -t "${session}:${target}" "$pipe_cmd"

if [[ -z "${TMUX:-}" ]]; then
  target_window="${target%%.*}"
  tmux select-window -t "${session}:${target_window}" 2>/dev/null || true
  tmux select-pane -t "${session}:${target}" 2>/dev/null || true
  echo "tmux session '${session}' ready. Logging pane ${target} to ${log_file}."
  exec tmux attach -t "$session"
else
  echo "tmux session '${session}' ready. Logging pane ${target} to ${log_file}."
fi
