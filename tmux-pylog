#!/usr/bin/env python3

import argparse
import os
import shlex
import shutil
import subprocess
import sys


DESCRIPTION = """\
Starts/attaches tmux session "ops" and logs a new window's pane 0 with a
Python filter that removes ANSI sequences and preserves the final line when
carriage returns or backspaces are used (e.g., Ctrl-R).
"""


PY_FILTER = r"""
import sys

buf = []
out = sys.stdout.buffer
inp = sys.stdin.buffer
cursor = 0
sav_cursor = 0
saw_cr = False
alt_screen = False
alt_suppressed = False

def read_byte():
    b = inp.read(1)
    if not b:
        return None
    return b[0]

def write_line():
    line = b"".join(buf)
    if should_suppress_line(line):
        out.write(b"[tui output suppressed]\n")
        out.flush()
        return
    out.write(line)
    out.write(b"\n")
    out.flush()

def reset_line():
    buf.clear()
    return 0

def should_suppress_line(line):
    if not line:
        return False
    if b"VIM - Vi IMproved" in line or b"AllVIM - Vi IMproved" in line:
        return True
    if b"Press ENTER or type command to continue" in line:
        return True
    if len(line) > 300:
        tildes = line.count(b"~")
        if tildes > 20 and tildes * 5 > len(line):
            return True
    return False

def insert_char(ch):
    global cursor
    if cursor < 0:
        cursor = 0
    if cursor >= len(buf):
        buf.append(ch)
    else:
        buf[cursor] = ch
    cursor += 1

def read_utf8_char(first_byte):
    if first_byte < 0x80:
        return bytes([first_byte])
    if 0xC2 <= first_byte <= 0xDF:
        needed = 1
    elif 0xE0 <= first_byte <= 0xEF:
        needed = 2
    elif 0xF0 <= first_byte <= 0xF4:
        needed = 3
    else:
        return b"?"
    seq = bytearray([first_byte])
    for _ in range(needed):
        b = read_byte()
        if b is None:
            return b"?"
        if b < 0x80 or b > 0xBF:
            return b"?"
        seq.append(b)
    return bytes(seq)

def handle_csi(final_byte, params, private):
    global cursor, sav_cursor, alt_screen, alt_suppressed, saw_cr
    if private and final_byte in (ord("h"), ord("l")):
        is_alt = any(p in (47, 1047, 1048, 1049) for p in params)
        if is_alt:
            if final_byte == ord("h"):
                alt_screen = True
                alt_suppressed = True
                cursor = reset_line()
                saw_cr = False
            else:
                if alt_suppressed:
                    out.write(b"[alt-screen suppressed]\n")
                    out.flush()
                    alt_suppressed = False
                alt_screen = False
                cursor = reset_line()
                saw_cr = False
            return
    if alt_screen:
        return
    if final_byte == ord("C"):  # cursor right
        cursor += params[0] if params else 1
        if cursor > len(buf):
            cursor = len(buf)
        return
    if final_byte == ord("D"):  # cursor left
        cursor -= params[0] if params else 1
        if cursor < 0:
            cursor = 0
        return
    if final_byte == ord("G"):  # cursor horizontal absolute (1-based)
        n = params[0] if params else 1
        cursor = max(0, n - 1)
        if cursor > len(buf):
            cursor = len(buf)
        return
    if final_byte in (ord("H"), ord("f")):  # cursor position (row;col)
        if params and len(params) >= 2:
            cursor = max(0, params[1] - 1)
        else:
            cursor = 0
        if cursor > len(buf):
            cursor = len(buf)
        return
    if final_byte == ord("s"):  # save cursor
        sav_cursor = cursor
        return
    if final_byte == ord("u"):  # restore cursor
        cursor = sav_cursor
        if cursor > len(buf):
            cursor = len(buf)
        if cursor < 0:
            cursor = 0
        return
    if final_byte == ord("K"):  # erase in line
        n = params[0] if params else 0
        if n == 0:
            del buf[cursor:]
        elif n == 1:
            del buf[:cursor]
            cursor = 0
        elif n == 2:
            cursor = reset_line()
        return
    if final_byte == ord("X"):  # erase chars
        n = params[0] if params else 1
        if n > 0:
            del buf[cursor:cursor + n]
        return
    if final_byte == ord("P"):  # delete chars
        n = params[0] if params else 1
        if n > 0:
            del buf[cursor:cursor + n]
        return
    if final_byte == ord("@"):  # insert blanks
        n = params[0] if params else 1
        if n > 0:
            buf[cursor:cursor] = [b" "] * n
        return

while True:
    c = read_byte()
    if c is None:
        if buf:
            out.write(b"".join(buf))
            out.flush()
        break

    if saw_cr:
        if c == 10:  # \n (CRLF)
            write_line()
            cursor = reset_line()
            saw_cr = False
            continue
        cursor = 0
        saw_cr = False

    if alt_screen and c != 27:
        continue

    if c == 10:  # \n
        write_line()
        cursor = reset_line()
        continue
    if c == 13:  # \r
        saw_cr = True
        continue
    if c == 7:  # BEL (readline "beep" on no match)
        continue
    if c == 8:  # backspace: move cursor left
        if cursor > 0:
            cursor -= 1
        continue
    if c == 127:  # delete
        if cursor < len(buf):
            del buf[cursor:cursor + 1]
        continue
    if c == 27:  # ESC: parse ANSI escape sequences
        n = read_byte()
        if n is None:
            break
        if n == 55:  # ESC 7: save cursor
            sav_cursor = cursor
            continue
        if n == 56:  # ESC 8: restore cursor
            cursor = sav_cursor
            if cursor > len(buf):
                cursor = len(buf)
            if cursor < 0:
                cursor = 0
            continue
        if n == 91:  # '[' (CSI)
            private = False
            params = []
            current = ""
            while True:
                n = read_byte()
                if n is None:
                    break
                if n == 63 and not current and not params:  # '?'
                    private = True
                    continue
                if 48 <= n <= 57:  # 0-9
                    current += chr(n)
                    continue
                if n == 59:  # ';'
                    params.append(int(current) if current else 0)
                    current = ""
                    continue
                if 64 <= n <= 126:
                    if current or params:
                        params.append(int(current) if current else 0)
                    handle_csi(n, params, private)
                    break
            continue
        if n == 93:  # ']' (OSC)
            prev = None
            while True:
                n = read_byte()
                if n is None:
                    break
                if n == 7:  # BEL
                    break
                if prev == 27 and n == 92:  # ESC \
                    break
                prev = n
            continue
        continue

    if c >= 0x80:
        insert_char(read_utf8_char(c))
    else:
        insert_char(bytes([c]))
"""


PY_TEE = r"""
import os
import sys

path = sys.argv[1]
max_bytes = int(sys.argv[2])
keep_bytes = int(sys.argv[3])
inp = sys.stdin.buffer
out = sys.stdout.buffer

def trim_file(path, keep_bytes):
    try:
        size = os.path.getsize(path)
    except FileNotFoundError:
        return 0
    if keep_bytes <= 0:
        with open(path, "wb"):
            pass
        return 0
    if size <= keep_bytes:
        return size

    start = max(0, size - keep_bytes)
    with open(path, "rb") as src:
        if start > 0:
            src.seek(start - 1)
            prev_byte = src.read(1)
        else:
            prev_byte = b"\n"
        src.seek(start)
        tail = src.read()

    if start > 0 and prev_byte != b"\n":
        newline = tail.find(b"\n")
        if newline != -1:
            tail = tail[newline + 1:]

    tmp_path = path + ".tmp"
    with open(tmp_path, "wb") as dst:
        dst.write(tail)
    os.replace(tmp_path, path)
    return len(tail)

try:
    size = os.path.getsize(path)
except FileNotFoundError:
    size = 0

if max_bytes > 0 and size > max_bytes:
    size = trim_file(path, keep_bytes)

log = open(path, "ab", buffering=0)
try:
    while True:
        chunk = inp.read(65536)
        if not chunk:
            break
        log.write(chunk)
        size += len(chunk)
        out.write(chunk)
        out.flush()
        if max_bytes > 0 and size > max_bytes:
            log.close()
            size = trim_file(path, keep_bytes)
            log = open(path, "ab", buffering=0)
finally:
    log.close()
"""


SIZE_SUFFIXES = {
    "k": 1024,
    "m": 1024 ** 2,
    "g": 1024 ** 3,
    "t": 1024 ** 4,
}

DEFAULT_MAX_BYTES = 50 * 1024 * 1024
DEFAULT_KEEP_BYTES = 40 * 1024 * 1024


def parse_size(value):
    if value is None:
        return None
    text = str(value).strip()
    if not text:
        return None
    suffix = text[-1].lower()
    multiplier = 1
    if suffix in SIZE_SUFFIXES:
        multiplier = SIZE_SUFFIXES[suffix]
        text = text[:-1].strip()
    elif len(text) > 1 and text[-2:].lower() in ("kb", "mb", "gb", "tb"):
        multiplier = SIZE_SUFFIXES[text[-2].lower()]
        text = text[:-2].strip()
    try:
        size = int(text)
    except ValueError as exc:
        raise argparse.ArgumentTypeError(
            f"invalid size '{value}'; use bytes or K/M/G/T suffixes"
        ) from exc
    if size < 0:
        raise argparse.ArgumentTypeError("size must be >= 0")
    return size * multiplier


def build_parser():
    parser = argparse.ArgumentParser(
        prog="tmux-pylog",
        description=DESCRIPTION,
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Default cap: 50 MiB per file, keeping the newest 40 MiB after pruning.\n"
            "Size caps apply independently to both the raw and cleaned logs.\n"
            "Environment: TMUX_PYLOG_MAX_BYTES, TMUX_PYLOG_KEEP_BYTES, TMUX_PYLOG_TERM"
        ),
    )
    parser.add_argument(
        "--max-bytes",
        metavar="SIZE",
        default=os.environ.get("TMUX_PYLOG_MAX_BYTES"),
        help="prune the oldest log content after a file grows past SIZE (default: 50M; supports K/M/G/T)",
    )
    parser.add_argument(
        "--keep-bytes",
        metavar="SIZE",
        default=os.environ.get("TMUX_PYLOG_KEEP_BYTES"),
        help="after pruning, keep roughly the newest SIZE bytes (default: 40M)",
    )
    return parser


def parse_args(argv):
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        args.max_bytes = parse_size(args.max_bytes)
        args.keep_bytes = parse_size(args.keep_bytes)
    except argparse.ArgumentTypeError as exc:
        parser.error(str(exc))

    if args.max_bytes is None:
        args.max_bytes = DEFAULT_MAX_BYTES
    if args.max_bytes == 0 and args.keep_bytes not in (None, 0):
        parser.error("--keep-bytes requires --max-bytes")
    if args.keep_bytes is None:
        if args.max_bytes == DEFAULT_MAX_BYTES:
            args.keep_bytes = DEFAULT_KEEP_BYTES
        else:
            args.keep_bytes = (args.max_bytes * 4) // 5 if args.max_bytes else 0
    if args.max_bytes and args.keep_bytes >= args.max_bytes:
        parser.error("--keep-bytes must be smaller than --max-bytes")
    return args


def run_tmux(args, capture=False, check=True):
    return subprocess.run(
        ["tmux", *args],
        check=check,
        text=True,
        capture_output=capture,
    )


def tmux_session_exists(name):
    return subprocess.run(
        ["tmux", "has-session", "-t", name],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    ).returncode == 0


def first_window_index(session):
    result = run_tmux(["list-windows", "-t", session, "-F", "#{window_index}"], capture=True)
    return result.stdout.strip().splitlines()[0]


def main():
    args = parse_args(sys.argv[1:])

    if not shutil.which("tmux"):
        print("tmux is required", file=sys.stderr)
        return 1

    session = "ops"
    pane_index = "0"
    created_session = False
    default_term = os.environ.get("TMUX_PYLOG_TERM", "screen-256color")

    if tmux_session_exists(session):
        run_tmux(["set-option", "-t", session, "default-terminal", default_term])
        result = run_tmux(["new-window", "-t", session, "-P", "-F", "#{window_index}"], capture=True)
        window_index = result.stdout.strip()
    else:
        run_tmux(["new-session", "-d", "-s", session])
        created_session = True
        initial_index = first_window_index(session)
        run_tmux(["set-option", "-t", session, "default-terminal", default_term])
        if initial_index:
            run_tmux(["respawn-window", "-k", "-t", f"{session}:{initial_index}"])
            window_index = initial_index
        else:
            result = run_tmux(["new-window", "-t", session, "-P", "-F", "#{window_index}"], capture=True)
            window_index = result.stdout.strip()

    target = f"{window_index}.{pane_index}"

    log_dir = os.path.join(os.path.expanduser("~"), ".cache", "tmux-log", session)
    os.makedirs(log_dir, exist_ok=True)
    log_file = os.path.join(log_dir, f"w{window_index}p{pane_index}.log")
    raw_log_file = os.path.join(log_dir, f"raw-w{window_index}p{pane_index}.log")

    python_cmd = f"{shlex.quote(sys.executable)} -u -c {shlex.quote(PY_FILTER)}"
    raw_writer_cmd = (
        f"{shlex.quote(sys.executable)} -u -c {shlex.quote(PY_TEE)} "
        f"{shlex.quote(raw_log_file)} {args.max_bytes} {args.keep_bytes}"
    )
    clean_writer_cmd = (
        f"{shlex.quote(sys.executable)} -u -c {shlex.quote(PY_TEE)} "
        f"{shlex.quote(log_file)} {args.max_bytes} {args.keep_bytes}"
    )

    pipe_cmd = (
        f"{raw_writer_cmd}"
        f" | {python_cmd}"
        f" | {clean_writer_cmd}"
    )

    run_tmux(["pipe-pane", "-t", f"{session}:{target}", ""])
    run_tmux(["pipe-pane", "-t", f"{session}:{target}", pipe_cmd])

    if "TMUX" not in os.environ:
        run_tmux(["select-window", "-t", f"{session}:{window_index}"])
        run_tmux(["select-pane", "-t", f"{session}:{target}"])
        os.execvp("tmux", ["tmux", "attach", "-t", session])

    if created_session:
        print(f"tmux session '{session}' ready. Logging pane {target} to {log_file}.")
    else:
        print(f"tmux session '{session}' ready. Logging new pane {target} to {log_file}.")
    return 0


if __name__ == "__main__":
    sys.exit(main())
