#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: tmux-redact [options]

Interactive helper to redact a secret from the ops tmux logs.

Options:
  -r, --replacement STR   replacement text (default: REDACTED)
  -n, --dry-run           report matches but do not modify files
  -h, --help              show this help message

Behavior:
- Rewrites the log file in-place to preserve the inode (no pipe restart).
- Targets ~/.cache/tmux-log/ops/*.log.
EOF
}

replacement="REDACTED"
dry_run=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    -r|--replacement)
      [[ $# -lt 2 ]] && { echo "Missing value for $1" >&2; exit 1; }
      replacement="$2"
      shift 2
      ;;
    -n|--dry-run)
      dry_run=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      break
      ;;
  esac
done

if ! command -v python3 >/dev/null 2>&1; then
  echo "python3 is required for redaction." >&2
  exit 1
fi

log_dir="$HOME/.cache/tmux-log/ops"
if [[ ! -d "$log_dir" ]]; then
  echo "Log directory not found: $log_dir" >&2
  exit 1
fi

shopt -s nullglob
log_files=("$log_dir"/*.log)
shopt -u nullglob
if [[ ${#log_files[@]} -eq 0 ]]; then
  echo "No log files found in $log_dir" >&2
  exit 1
fi

read -r -s -p "Secret to redact: " secret
echo
if [[ -z "$secret" ]]; then
  echo "Nothing entered. Aborting." >&2
  exit 1
fi

redact_file() {
  local path="$1"
  if [[ ! -f "$path" ]]; then
    return 0
  fi
  if ! out="$(SECRET="$secret" REPLACEMENT="$replacement" DRY_RUN="$dry_run" python3 - "$path" 2>&1 <<'PY'
import sys
import os
from pathlib import Path

secret = os.environ.get("SECRET", "").encode("utf-8", "surrogatepass")
replacement = os.environ.get("REPLACEMENT", "REDACTED").encode("utf-8", "surrogatepass")
dry_run = os.environ.get("DRY_RUN", "0")
if not secret:
    sys.exit(1)
path = Path(sys.argv[1])
with path.open("r+b") as f:
    raw = f.read()
    count = raw.count(secret)
    if count and dry_run != "1":
        raw = raw.replace(secret, replacement)
        f.seek(0)
        f.truncate(0)
        f.write(raw)
print(count)
PY
  )"; then
    echo "python3 failed: $out" >&2
    return 1
  fi
  printf '%s' "$out"
}

total=0
count=0
for path in "${log_files[@]}"; do
  name="$(basename "$path")"
  if count="$(redact_file "$path")"; then
    echo "${name}: ${count} match(es)"
    total=$((total + count))
  else
    echo "Failed to process ${name}" >&2
    exit 1
  fi
done

if [[ $dry_run -eq 1 ]]; then
  echo "Dry run complete. ${total} total match(es) found in ${#log_files[@]} ops log(s)."
else
  echo "Redacted ${total} occurrence(s) across ${#log_files[@]} ops log(s)."
fi
